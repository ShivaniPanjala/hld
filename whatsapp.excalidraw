    {
      "id": "h-gyFGMnVbH-WI-5EjzoD",
      "type": "text",
      "x": 369,
      "y": 1293,
      "width": 1205.919189453125,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
