    {
      "id": "fYpRrYOtJscRwcwz_wXgP",
      "type": "text",
      "x": -5424.560137469067,
      "y": -1275.2943508263345,
      "width": 519.1992797851562,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 1450665769,
      "version": 456,
      "versionNonce": 1640559751,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780769790418,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- users should able to create group chats (limit 100 users)\n- users should be able to send/recieve messages\n- users should recieve messages when they are not online\n(upto 30 days)\n- users should be able to send/recieve media\n\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- users should able to create group chats (limit 100 users)\n- users should be able to send/recieve messages\n- users should recieve messages when they are not online\n(upto 30 days)\n- users should be able to send/recieve media\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qkG6nFBb_LKd8NzH4mSiA",
      "type": "text",
      "x": -4596.304041157251,
      "y": -1292.7150240170936,
      "width": 448.79937744140625,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0E",
      "roundness": null,
      "seed": 483041799,
      "version": 401,
      "versionNonce": 1642515367,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780769790418,
      "link": null,
      "locked": false,
      "text": "Non Functional Requirements\n- should deliver messages with low latency (<500Ms)\n- gurantee delivery of messages\n- handle billions of users\n- messages are not stored unnecessarily\n- fault tolerance",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non Functional Requirements\n- should deliver messages with low latency (<500Ms)\n- gurantee delivery of messages\n- handle billions of users\n- messages are not stored unnecessarily\n- fault tolerance",
      "autoResize": true,
      "lineHeight": 1.25
    },
