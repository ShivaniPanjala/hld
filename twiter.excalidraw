    {
      "id": "ON1J4n-V_xzBQ1mws_6AN",
      "type": "text",
      "x": 267.8130801339114,
      "y": 1386.014663284503,
      "width": 641.1444091796875,
      "height": 199.42613771250527,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b17",
      "roundness": null,
      "seed": 1466401228,
      "version": 356,
      "versionNonce": 1162052684,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783670305994,
      "link": null,
      "locked": false,
      "text": "Read Flow:\n\n- Client asks tweet 123.\n- Tweet CRUD Service loads the tweet from Tweet Content DB.\n- Tweet Service then asks Reply Service:\n    - \"Give me replies for tweet 123.\"\n- Reply Service queries Reply DB.\n- Reply Service returns replies.\n- Tweet Service combines both into one response and store them in Cache",
      "fontSize": 17.726767796667136,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Read Flow:\n\n- Client asks tweet 123.\n- Tweet CRUD Service loads the tweet from Tweet Content DB.\n- Tweet Service then asks Reply Service:\n    - \"Give me replies for tweet 123.\"\n- Reply Service queries Reply DB.\n- Reply Service returns replies.\n- Tweet Service combines both into one response and store them in Cache",
      "autoResize": true,
      "lineHeight": 1.25
    },
