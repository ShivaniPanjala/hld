    {
      "id": "tkkSUkeDyKYzp3WJFLtKY",
      "type": "text",
      "x": 879.4782251214973,
      "y": 1718.278583898104,
      "width": 983.039306640625,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0x",
      "roundness": null,
      "seed": 1596330484,
      "version": 732,
      "versionNonce": 168344564,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783670775246,
      "link": null,
      "locked": false,
      "text": "Why Replies are stored in Seperated DB\n1. Scalability\n    -> Popular tweets can get thousands of replies so storing them seperately \n        not only ensures that the Tweet Content DB doesn't become too large \n        but more importantly it allows to scale the reply service entirely independently\n2. Performance\n    -> we can fetch a tweet without loading all of its replies this makes read really fast for a tweet",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why Replies are stored in Seperated DB\n1. Scalability\n    -> Popular tweets can get thousands of replies so storing them seperately \n        not only ensures that the Tweet Content DB doesn't become too large \n        but more importantly it allows to scale the reply service entirely independently\n2. Performance\n    -> we can fetch a tweet without loading all of its replies this makes read really fast for a tweet",
      "autoResize": true,
      "lineHeight": 1.25
    },
