    {
      "id": "q01TjIVcfF8QlXJC2DaFU",
      "type": "text",
      "x": -1642.9899987117888,
      "y": 3382.893181098306,
      "width": 1399.1826171875,
      "height": 568.8744703368966,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Z",
      "roundness": null,
      "seed": 172245492,
      "version": 183,
      "versionNonce": 902482380,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783681759081,
      "link": null,
      "locked": false,
      "text": "\nAlice -----> Bob, Charlie\nIdea: When a user posts a tweet, immediately push the Tweet ID into each follower's timeline.\n\nFlow\nBob tweets\n    │\n    ▼\nTweet Service\n    │\nSave Tweet in Tweet DB\n    │\nFind Bob's followers (Follow DB)\n    │\nInsert Tweet ID into each follower's Timeline DB",
      "fontSize": 30.33997175130115,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nAlice -----> Bob, Charlie\nIdea: When a user posts a tweet, immediately push the Tweet ID into each follower's timeline.\n\nFlow\nBob tweets\n    │\n    ▼\nTweet Service\n    │\nSave Tweet in Tweet DB\n    │\nFind Bob's followers (Follow DB)\n    │\nInsert Tweet ID into each follower's Timeline DB",
      "autoResize": true,
      "lineHeight": 1.25
    },
