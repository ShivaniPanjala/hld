      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- create, edit & delete user\n- Like, reply & retweet\n- search for tweets\n- Follow other users\n- users should be able to view tweets from users they follow on their homepage\n- create a account and login the user\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- create, edit & delete user\n- Like, reply & retweet\n- search for tweets\n- Follow other users\n- users should be able to view tweets from users they follow on their homepage\n- create a account and login the user\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
