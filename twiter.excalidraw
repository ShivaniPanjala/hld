      "groupIds": [],
      "frameId": null,
      "index": "b1r",
      "roundness": null,
      "seed": 2077180364,
      "version": 269,
      "versionNonce": 1850863604,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783681741030,
      "link": null,
      "locked": false,
      "text": "Note:\nFan-out-on-Write \n    -> precomputes each user's timeline by pushing Tweet IDs to followers when a tweet is created. \n    -> It provides fast reads but expensive writes, making it suitable for normal users.\n\nFan-out-on-Read \n    -> builds part of the timeline when the user requests it by fetching tweets dynamically from high-fan-out accounts. \n    -> It provides cheap writes but more expensive reads, making it suitable for celebrities.",
      "fontSize": 41.4705550612621,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note:\nFan-out-on-Write \n    -> precomputes each user's timeline by pushing Tweet IDs to followers when a tweet is created. \n    -> It provides fast reads but expensive writes, making it suitable for normal users.\n\nFan-out-on-Read \n    -> builds part of the timeline when the user requests it by fetching tweets dynamically from high-fan-out accounts. \n    -> It provides cheap writes but more expensive reads, making it suitable for celebrities.",
      "autoResize": false,
      "lineHeight": 1.25
    },
