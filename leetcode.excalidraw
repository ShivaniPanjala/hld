    {
      "id": "wVnGz9wkjOaHg7EPNzQCn",
      "type": "text",
      "x": -186,
      "y": 6477,
      "width": 927.7431640625,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1N",
      "roundness": null,
      "seed": 1906048486,
      "version": 17,
      "versionNonce": 904950246,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784810608547,
      "link": null,
      "locked": false,
      "text": "Each supported language has a test harness and helper classes (e.g., TreeNode, ListNode) inside its runtime container.\nWhen a submission is executed:\n- The Worker fetches the test cases from the database.\n- It starts the appropriate language container.\n- The test harness reads the serialized input.\n- The harness deserializes the input into language-specific objects (e.g., converts the array into a TreeNode object).\n- The harness invokes the user's solution with the deserialized input.\n- The returned output is compared with the expected output.\n- If all test cases pass, the submission is marked Accepted; otherwise, it returns the failed test case details.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each supported language has a test harness and helper classes (e.g., TreeNode, ListNode) inside its runtime container.\nWhen a submission is executed:\n- The Worker fetches the test cases from the database.\n- It starts the appropriate language container.\n- The test harness reads the serialized input.\n- The harness deserializes the input into language-specific objects (e.g., converts the array into a TreeNode object).\n- The harness invokes the user's solution with the deserialized input.\n- The returned output is compared with the expected output.\n- If all test cases pass, the submission is marked Accepted; otherwise, it returns the failed test case details.",
      "autoResize": true,
      "lineHeight": 1.25
    },
