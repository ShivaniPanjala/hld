  "elements": [
    {
      "id": "AqxIMLUNhcJ4zh9KDz09A",
      "type": "text",
      "x": 187.53515625,
      "y": 50.640625,
      "width": 810.3995361328125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a0",
      "roundness": null,
      "seed": 2130083514,
      "version": 384,
      "versionNonce": 943178938,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784641703249,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- users should be able to view list of problems\n- should be able to view the given problem and code a solution in multiple languages\n- submit the solution and get instant feedback\n- should be able to view leaderboard for competitions",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- users should be able to view list of problems\n- should be able to view the given problem and code a solution in multiple languages\n- submit the solution and get instant feedback\n- should be able to view leaderboard for competitions",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ycWw0gZ0-PXk1642Im6IR",
      "type": "text",
      "x": 199,
      "y": 228.234375,
      "width": 944.7393798828125,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 364001894,
      "version": 564,
      "versionNonce": 1372752038,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784804425077,
      "link": null,
      "locked": false,
      "text": "Non-Functional Requirements\n- Isolation and security when running user code\n- low latency - return submission results < 5ms\n- Availability over consistency\n- should be scale to support competitions with 100000 users\n\n\nEntites\n- Problem -> which stores problem statement, testcase, expected o/p\n- submission -> users code submissions and the result of running the code againt the test cases\n- Leaderboard -> store the leaderboard for competitions",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-Functional Requirements\n- Isolation and security when running user code\n- low latency - return submission results < 5ms\n- Availability over consistency\n- should be scale to support competitions with 100000 users\n\n\nEntites\n- Problem -> which stores problem statement, testcase, expected o/p\n- submission -> users code submissions and the result of running the code againt the test cases\n- Leaderboard -> store the leaderboard for competitions",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oD1bcCar9gh4s8-SjWUgu",
      "type": "text",
      "x": 231.26953125,
      "y": 590.26953125,
      "width": 609.1195678710938,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 1422303782,
      "version": 288,
      "versionNonce": 771236454,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784642738129,
      "link": null,
      "locked": false,
      "text": "API's\n\nGET \n/problems?page=1&limit=100  -> Partial<Problem>[]\n\nGET\n/problems/:id?language={language} -> Problem\n\nPOST\n/problems/:id/submit\n    Body : {\n        language\n        code\n    }\nRes -> Submission\n\nGET\n/leaderboard/:competitionId?page=1&limit=100  -> Leaderboard",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API's\n\nGET \n/problems?page=1&limit=100  -> Partial<Problem>[]\n\nGET\n/problems/:id?language={language} -> Problem\n\nPOST\n/problems/:id/submit\n    Body : {\n        language\n        code\n    }\nRes -> Submission\n\nGET\n/leaderboard/:competitionId?page=1&limit=100  -> Leaderboard",
      "autoResize": true,
      "lineHeight": 1.25
    },
