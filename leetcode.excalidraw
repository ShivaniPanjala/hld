      "seed": 1267657318,
      "version": 170,
      "versionNonce": 553496486,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784804250113,
      "link": null,
      "locked": false,
      "text": "Security\n- Docker for isolation\n- Read only filesystem(writes to temp)\n- explicit timeout\n- cpu and Memory bounds\n- VPC for network controls",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Security\n- Docker for isolation\n- Read only filesystem(writes to temp)\n- explicit timeout\n- cpu and Memory bounds\n- VPC for network controls",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aiUDYbPpTGL5YN_bVuLtV",
      "type": "text",
      "x": -216.36745875814688,
      "y": 6129.75,
      "width": 524.3776245117188,
      "height": 27.285156250000004,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
