    {
      "id": "MVMHUhINw_yt7liKpgoTP",
      "type": "text",
      "x": -225.40185546875,
      "y": 4880.53515625,
      "width": 551.1396484375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
