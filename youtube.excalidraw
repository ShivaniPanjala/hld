      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem: Suddenly 1M uploads Service cannot process all the req immediately\nSolution:\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7qfp4ZU_m68XitGUlYBes",
      "type": "text",
      "x": -2861.794932746219,
      "y": 30074.289307036328,
      "width": 503.1556288058234,
      "height": 96.59728130868285,
