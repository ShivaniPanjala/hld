    {
      "id": "9gGzaynEBaIduVMCGVwiP",
      "type": "text",
      "x": -3466.341891998395,
      "y": 23785.015947786665,
      "width": 5108.1416015625,
      "height": 859.7473338953741,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2E",
      "roundness": null,
      "seed": 811498943,
      "version": 263,
      "versionNonce": 1205880799,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783335065468,
      "link": null,
      "locked": false,
      "text": "    - Stateless(treats every request as completely new, with no memory of previous events)\n    - This service does:\n        - Get Presigned URL\n        - Get Video Metadata\n    - More Traffic then \n        - Add More servers",
      "fontSize": 114.63297785271655,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    - Stateless(treats every request as completely new, with no memory of previous events)\n    - This service does:\n        - Get Presigned URL\n        - Get Video Metadata\n    - More Traffic then \n        - Add More servers",
      "autoResize": true,
      "lineHeight": 1.25
    },
