      "link": null,
      "locked": false,
      "text": "Cache(Redis)",
      "fontSize": 84.01750430596218,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cache(Redis)",
      "autoResize": true,
