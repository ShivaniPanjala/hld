      "updated": 1783061968950,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- Users should be able to upload videos\n- Users should watch videos\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- Users should be able to upload videos\n- Users should watch videos\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GiegCCtJAwN5cSzTH2yhr",
      "type": "text",
      "x": 954,
      "y": 67,
      "width": 659.7994384765625,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 52449599,
      "version": 293,
      "versionNonce": 34774463,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783062113619,
      "link": null,
      "locked": false,
      "text": "Non-Functional Requirements\n- Prioritize Availability over Consistency (Availability > Consistency)\n- Low latency streaming(even if low bandwidth)\n- high scale\n- support large (10gb) videos\n- Resumable videos\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-Functional Requirements\n- Prioritize Availability over Consistency (Availability > Consistency)\n- Low latency streaming(even if low bandwidth)\n- high scale\n- support large (10gb) videos\n- Resumable videos\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
