      "boundElements": null,
      "updated": 1783319199848,
      "link": null,
      "locked": false,
      "text": "Raw Video\n    ↓\nCodec (H.264 / AV1)\n    ↓\nContainer (MP4 / WebM)\n    ↓\nMultiple Bitrates\n(1080p, 720p, 480p)\n    ↓\nSplit into Segments\n    ↓\nManifest Files\n    ↓\nPlayer Streams Video",
      "fontSize": 72.62576163623987,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Raw Video\n    ↓\nCodec (H.264 / AV1)\n    ↓\nContainer (MP4 / WebM)\n    ↓\nMultiple Bitrates\n(1080p, 720p, 480p)\n    ↓\nSplit into Segments\n    ↓\nManifest Files\n    ↓\nPlayer Streams Video",
      "autoResize": true,
      "lineHeight": 1.25
    },
