    {
      "id": "w8dW4zv2kXJgyuXJJkvMC",
      "type": "text",
      "x": -3388.7512529092196,
      "y": 24721.383447183416,
      "width": 2117.3074952602237,
      "height": 151.76254288668193,
      "angle": 0,
