      "versionNonce": 1880689745,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783319105137,
      "link": null,
      "locked": false,
      "text": "Non-Functional Requirements\n- Prioritize Availability over Consistency\n(Availability > Consistency)\n- Low latency streaming(even if low\nbandwidth)\n- high scale\n- support large (10gb) videos\n- Resumable videos\n",
      "fontSize": 82.88561576451517,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-Functional Requirements\n- Prioritize Availability over Consistency (Availability > Consistency)\n- Low latency streaming(even if low bandwidth)\n- high scale\n- support large (10gb) videos\n- Resumable videos\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
