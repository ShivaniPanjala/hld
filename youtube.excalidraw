      "roundness": null,
      "seed": 1995899889,
      "version": 1198,
      "versionNonce": 1668525105,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783319163000,
      "link": null,
      "locked": false,
      "text": "User Uploads Video\n    ↓\nS3 Stores Original Video\n    ↓\nS3 Event Notification\n    ↓\nVideo Processing Service\n    ↓\nCreate Multiple Qualities\n(1080p, 720p, 480p)\n    ↓\nSplit Each Quality into Segments\n    ↓\nGenerate Manifest File\n    ↓\nStore Segments + Manifest in S3\n    ↓\nUpdate VideoMetadata\n(with Manifest URL)",
      "fontSize": 95.29004950083771,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User Uploads Video\n    ↓\nS3 Stores Original Video\n    ↓\nS3 Event Notification\n    ↓\nVideo Processing Service\n    ↓\nCreate Multiple Qualities\n(1080p, 720p, 480p)\n    ↓\nSplit Each Quality into Segments\n    ↓\nGenerate Manifest File\n    ↓\nStore Segments + Manifest in S3\n    ↓\nUpdate VideoMetadata\n(with Manifest URL)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dCPGZCcdjoMvLfClsI2kB",
      "type": "text",
      "x": -2842.0524660084184,
      "y": 8573.764993117107,
      "width": 3687.177490234375,
      "height": 2242.4248549763383,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 2014547007,
      "version": 1221,
      "versionNonce": 582089361,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783340965389,
      "link": null,
      "locked": false,
      "text": "User Requests Video\n    ↓\nClient Fetches VideoMetadata using \nGET /video/:vidoeId -> videoMetadata which has s3 Manifest url's\n    ↓\nClient Gets Manifest URL\n    ↓\nClient Downloads Manifest from S3\n    ↓\nClient Chooses Quality\n    ↓\nClient Downloads Segments from S3\n    ↓\nNetwork Changes?\n    ↓\nDownload Higher/Lower Quality Segments",
      "fontSize": 112.12124274881691,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User Requests Video\n    ↓\nClient Fetches VideoMetadata using \nGET /video/:vidoeId -> videoMetadata which has s3 Manifest url's\n    ↓\nClient Gets Manifest URL\n    ↓\nClient Downloads Manifest from S3\n    ↓\nClient Chooses Quality\n    ↓\nClient Downloads Segments from S3\n    ↓\nNetwork Changes?\n    ↓\nDownload Higher/Lower Quality Segments",
      "autoResize": true,
      "lineHeight": 1.25
    },
