      "boundElements": null,
      "updated": 1783176211789,
      "link": null,
      "locked": false,
      "text": "User Uploads Video\n    ↓\nS3 Stores Original Video\n    ↓\nS3 Event Notification\n    ↓\nVideo Processing Service\n    ↓\nCreate Multiple Qualities\n(1080p, 720p, 480p)\n    ↓\nSplit Each Quality into Segments\n    ↓\nGenerate Manifest File\n    ↓\nStore Segments + Manifest in S3\n    ↓\nUpdate VideoMetadata\n(with Manifest URL)",
      "fontSize": 64.61013410197458,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User Uploads Video\n    ↓\nS3 Stores Original Video\n    ↓\nS3 Event Notification\n    ↓\nVideo Processing Service\n    ↓\nCreate Multiple Qualities\n(1080p, 720p, 480p)\n    ↓\nSplit Each Quality into Segments\n    ↓\nGenerate Manifest File\n    ↓\nStore Segments + Manifest in S3\n    ↓\nUpdate VideoMetadata\n(with Manifest URL)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dCPGZCcdjoMvLfClsI2kB",
      "type": "text",
      "x": 1050.5745627977412,
      "y": 1941.1087646755113,
      "width": 3795.9124254277226,
      "height": 1401.1064952856523,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 2014547007,
      "version": 551,
      "versionNonce": 2118545489,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783176247139,
      "link": null,
      "locked": false,
      "text": "User Requests Video\n    ↓\nClient Fetches VideoMetadata using GET /video/:vidoeId -> videoMetadata which has s3 Manifest url's\n    ↓\nClient Gets Manifest URL\n    ↓\nClient Downloads Manifest from S3\n    ↓\nClient Chooses Quality\n    ↓\nClient Downloads Segments from S3\n    ↓\nNetwork Changes?\n    ↓\nDownload Higher/Lower Quality Segments",
      "fontSize": 74.72567974856811,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User Requests Video\n    ↓\nClient Fetches VideoMetadata using GET /video/:vidoeId -> videoMetadata which has s3 Manifest url's\n    ↓\nClient Gets Manifest URL\n    ↓\nClient Downloads Manifest from S3\n    ↓\nClient Chooses Quality\n    ↓\nClient Downloads Segments from S3\n    ↓\nNetwork Changes?\n    ↓\nDownload Higher/Lower Quality Segments",
      "autoResize": true,
      "lineHeight": 1.25
    },
