      "isDeleted": false,
      "boundElements": [],
      "updated": 1783340973986,
      "link": null,
      "locked": false,
      "text": "Interview Note\nFan-out = Split work into many independent tasks.\nFan-in = Wait for all tasks to finish and combine results.\nDAG = Workflow where tasks have dependencies and no cycles.\nTranscoding = Most expensive CPU-bound step.\nTemporal = Orchestrates the workflow.\nS3 = Shared storage for intermediate files and segment URLs.",
      "fontSize": 103.43297876957237,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Interview Note\nFan-out = Split work into many independent tasks.\nFan-in = Wait for all tasks to finish and combine results.\nDAG = Workflow where tasks have dependencies and no cycles.\nTranscoding = Most expensive CPU-bound step.\nTemporal = Orchestrates the workflow.\nS3 = Shared storage for intermediate files and segment URLs.",
      "autoResize": true,
      "lineHeight": 1.25
    },
