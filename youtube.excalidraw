      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- Users should be able to upload videos\n- Users should watch videos",
      "fontSize": 98.23931773844872,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- Users should be able to upload videos\n- Users should watch videos",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GiegCCtJAwN5cSzTH2yhr",
      "type": "text",
      "x": -2474.285415660175,
      "y": -269.1194454426918,
      "width": 1880.3388743093867,
      "height": 932.4631773507965,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 52449599,
      "version": 1534,
      "versionNonce": 1880689745,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783319105137,
      "link": null,
      "locked": false,
      "text": "Non-Functional Requirements\n- Prioritize Availability over Consistency\n(Availability > Consistency)\n- Low latency streaming(even if low\nbandwidth)\n- high scale\n- support large (10gb) videos\n- Resumable videos\n",
      "fontSize": 82.88561576451517,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-Functional Requirements\n- Prioritize Availability over Consistency (Availability > Consistency)\n- Low latency streaming(even if low bandwidth)\n- high scale\n- support large (10gb) videos\n- Resumable videos\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
