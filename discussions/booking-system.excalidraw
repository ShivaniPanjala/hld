      "isDeleted": false,
      "boundElements": null,
      "updated": 1778309115218,
      "link": null,
      "locked": false,
      "text": "select * from Theater \nJOIN Show on Theater.Id = Show.theaterId\nShow JOIN Movie on Show.MovieId = Movie.Id\nShow JOIN Seats on Show.SeatId = Seat.Id\ngroupby show.Id agg count(Seat.Id)\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "select * from Theater \nJOIN Show on Theater.Id = Show.theaterId\nShow JOIN Movie on Show.MovieId = Movie.Id\nShow JOIN Seats on Show.SeatId = Seat.Id\ngroupby show.Id agg count(Seat.Id)\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
