      "type": "text",
      "x": 755.2880375715196,
      "y": 2050.430836685172,
      "width": 687.2394409179688,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0d",
      "roundness": null,
      "seed": 1478399678,
      "version": 647,
      "versionNonce": 293669630,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783943137114,
      "link": null,
      "locked": false,
      "text": "Before uploading, the client splits the file:\n        chunk1\n        chunk2\n        chunk3\nNow this chunk file is hashed using any hashing algorithms like sha256\n then we get the hashId which will be the fingerPrint",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Before uploading, the client splits the file:\n        chunk1\n        chunk2\n        chunk3\nNow this chunk file is hashed using any hashing algorithms like sha256\n then we get the hashId which will be the fingerPrint",
      "autoResize": true,
      "lineHeight": 1.25
    },
