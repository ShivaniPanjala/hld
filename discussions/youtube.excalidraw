      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Entities\n- User\n- Video \n- videometada\n\nAPi's\n\nPOST /presigned_url\n    body : { videometada}\n\nGET /video/:videoId\n    res: { videoMetadata }",
