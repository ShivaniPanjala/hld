      "isDeleted": false,
      "boundElements": null,
      "updated": 1784206706522,
      "link": null,
      "locked": false,
      "text": "2. Advertisers can query ad click metrics over time at 1 minute intervals",
      "fontSize": 28,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. Advertisers can query ad click metrics over time at 1 minute intervals",
      "autoResize": true,
      "lineHeight": 1.15
    },
    {
      "id": "j2Z0179h1qe8SxbbZPUWt",
      "type": "text",
      "x": -1031.1003313479223,
      "y": 4161.8484375,
      "width": 862.8344517583441,
      "height": 44.76562500000003,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1B",
      "roundness": null,
      "seed": 1734773687,
      "version": 858,
      "versionNonce": 1007255159,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784210751771,
      "link": null,
      "locked": false,
      "text": "Why do we need stream Processor like Flink, \ncan't we just use kafka consumers that keep a running count and flush to the DB every minute? ",
      "fontSize": 19.46331521739132,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why do we need stream Processor like Flink, \ncan't we just use kafka consumers that keep a running count and flush to the DB every minute? ",
      "autoResize": false,
      "lineHeight": 1.15
    },
