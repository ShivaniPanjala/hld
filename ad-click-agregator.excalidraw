      "updated": 1784211817224,
      "link": null,
      "locked": false,
      "text": "Automatically groups events into time windows (e.g., every minute).",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Automatically groups events into time windows (e.g., every minute).",
