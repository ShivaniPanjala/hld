    {
      "id": "KsXXfhMImpYevxUsdEN-F",
      "type": "text",
      "x": -1118.80078125,
      "y": 1453.41015625,
      "width": 537.0195922851562,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1D",
      "roundness": null,
      "seed": 1290213689,
      "version": 255,
      "versionNonce": 358793465,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784205205364,
      "link": null,
      "locked": false,
      "text": "Suppose you own Nike Ads\nEvery time Someone clicks an ad, an event is generated\n9:01:10  User A clicked Ad-1\n9:01:12  User B clicked Ad-1\n9:01:15  User C clicked Ad-2\n9:01:20  User D clicked Ad-1\n\nNow advertisers want to see a graph like\nMinute        Ad-1 Clicks\n9:01          3\n9:02          5\n9:03          2\n\nAnd they don't want to wait an hour\nThey want almost real time updates.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Suppose you own Nike Ads\nEvery time Someone clicks an ad, an event is generated\n9:01:10  User A clicked Ad-1\n9:01:12  User B clicked Ad-1\n9:01:15  User C clicked Ad-2\n9:01:20  User D clicked Ad-1\n\nNow advertisers want to see a graph like\nMinute        Ad-1 Clicks\n9:01          3\n9:02          5\n9:03          2\n\nAnd they don't want to wait an hour\nThey want almost real time updates.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VE0_mkSxHV2HBaLRd7yCz",
      "type": "text",
      "x": -1120.0915622081802,
      "y": 2803.95546875,
      "width": 233.38548278808594,
      "height": 31.742187500000014,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
