      "isDeleted": false,
      "boundElements": null,
      "updated": 1784203820478,
      "link": null,
      "locked": false,
      "text": "1. Users should be able to click the ad and be redirected to target",
      "fontSize": 28,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Users should be able to click the ad and be redirected to target",
      "autoResize": true,
      "lineHeight": 1.15
    },
    {
      "id": "fdGvDgq0UsSjQgqW0R3Yh",
      "type": "text",
      "x": -1142.8828125,
      "y": 1106.01171875,
      "width": 1000.3992919921875,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b16",
      "roundness": null,
      "seed": 1262929657,
      "version": 826,
      "versionNonce": 202443383,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784206646586,
      "link": null,
      "locked": false,
      "text": "- ad placement service will be placing the adds in the client Browser\n- when user clicks the add\n- we send a post request to click processor service with click data\n- click Processor will get the redirect Url form AdDb using adId\n- Click Processor will send the redirectUrl to the advertiser's website via a 302(redirect) status code\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- ad placement service will be placing the adds in the client Browser\n- when user clicks the add\n- we send a post request to click processor service with click data\n- click Processor will get the redirect Url form AdDb using adId\n- Click Processor will send the redirectUrl to the advertiser's website via a 302(redirect) status code\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dW4a2M6L-0aRM7LhHaXf9",
      "type": "text",
      "x": -1168.9885768579402,
      "y": 1276.710546875,
      "width": 845.0114135742188,
      "height": 32.199999999999996,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
