    {
      "id": "RzMB4HvJWqqJwOYxDTFHK",
      "type": "text",
      "x": -1055,
      "y": 6331,
      "width": 927.023193359375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
