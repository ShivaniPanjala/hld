    {
      "id": "zM3T-OwczOL7YhX6UMJF7",
      "type": "text",
      "x": -1023.453125,
      "y": 4013.40703125,
      "width": 446.36761474609375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1u",
      "roundness": null,
      "seed": 338804087,
      "version": 134,
      "versionNonce": 1305340313,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784210649311,
      "link": null,
      "locked": false,
      "text": "Instead of counting forever... we count for a time period\nEx: \n    window = 1 minute\n    9:01:00 ------------ 9:01:59\nAll clicks inside belong to one bucket.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Instead of counting forever... we count for a time period\nEx: \n    window = 1 minute\n    9:01:00 ------------ 9:01:59\nAll clicks inside belong to one bucket.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "OvQ5gKMgTmZ-cso5ys6S_",
      "type": "text",
      "x": -1021,
      "y": 4125,
      "width": 381.95172119140625,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
