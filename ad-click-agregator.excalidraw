      "roundness": null,
      "seed": 1176598487,
      "version": 48,
      "versionNonce": 1946549431,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784210700105,
      "link": null,
      "locked": false,
      "text": "when the window ends, flink flushes to OLAP DB",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "when the window ends, flink flushes to OLAP DB",
      "autoResize": true,
