      "boundElements": null,
      "updated": 1784197313978,
      "link": null,
      "locked": false,
      "text": "Data Flow\n1. Click data comes into system \n2. user is redirected \n3. click data is validated\n4. click data is logged \n5. Click data is aggregated\n6. aggregated data is queried",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Data Flow\n1. Click data comes into system \n2. user is redirected \n3. click data is validated\n4. click data is logged \n5. Click data is aggregated\n6. aggregated data is queried",
      "autoResize": true,
      "lineHeight": 1.25
    },
