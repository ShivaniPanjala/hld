    },
    {
      "id": "mU8oOydlIFogWc1f3Kiz4",
      "type": "text",
      "x": -1100.84765625,
      "y": 2415.015625,
      "width": 1244.8631591796875,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1U",
      "roundness": null,
      "seed": 784034073,
      "version": 87,
      "versionNonce": 200902105,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784206562150,
      "link": null,
      "locked": false,
      "text": "\n\nHigh Latency: \n    - Since Spark runs at fixed intervals (e.g., every minute), advertisers always see data that is a few minutes old rather than real-time.\nTraffic Spikes: \n    - During sudden bursts of clicks, the event store experiences high write load, and the Spark job has to process a much larger batch.\nCascading Delays\n    - If a Spark job takes longer than the batch interval, subsequent jobs get delayed, causing increasingly stale analytics.\nQueue Alone Isn't Enough: \n    - Adding a queue (Kafka/Kinesis) before the event store can absorb write spikes but does not reduce query latency, because processing is still batch-based",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n\nHigh Latency: \n    - Since Spark runs at fixed intervals (e.g., every minute), advertisers always see data that is a few minutes old rather than real-time.\nTraffic Spikes: \n    - During sudden bursts of clicks, the event store experiences high write load, and the Spark job has to process a much larger batch.\nCascading Delays\n    - If a Spark job takes longer than the batch interval, subsequent jobs get delayed, causing increasingly stale analytics.\nQueue Alone Isn't Enough: \n    - Adding a queue (Kafka/Kinesis) before the event store can absorb write spikes but does not reduce query latency, because processing is still batch-based",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LOP4lAkxHQfFsVi_wNRAk",
      "type": "text",
      "x": -1107.2824401855469,
      "y": 2415.3875,
      "width": 337.27972412109375,
      "height": 23,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1V",
      "roundness": null,
      "seed": 127166967,
      "version": 97,
      "versionNonce": 1985831609,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784206562150,
      "link": null,
      "locked": false,
      "text": "Limitations of Batch Processing (Spark)",
      "fontSize": 20,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Limitations of Batch Processing (Spark)",
      "autoResize": true,
      "lineHeight": 1.15
    },
    {
      "id": "yZIxEk59zLQqlTz2fjuI_",
      "type": "text",
      "x": -1156.171875,
      "y": 1326.125,
      "width": 730.5913696289062,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Y",
      "roundness": null,
      "seed": 1188633815,
      "version": 69,
      "versionNonce": 1755154839,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784206728523,
      "link": null,
      "locked": false,
      "text": "Our users were successfully redirected, now let's focus on the advertisers. \nThey need to be able to quickly query metrics about their ads to see how they're performing.\nOnce our /click endpoint receives a request what happens next?",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Our users were successfully redirected, now let's focus on the advertisers. \nThey need to be able to quickly query metrics about their ads to see how they're performing.\nOnce our /click endpoint receives a request what happens next?",
      "autoResize": true,
      "lineHeight": 1.25
    },
