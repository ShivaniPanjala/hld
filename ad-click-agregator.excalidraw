    },
    {
      "id": "Yycz6e3PpHTUvAqGLL-fn",
      "type": "text",
      "x": -950.6328125,
      "y": 5367.5703125,
      "width": 470.6875,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2G",
      "roundness": null,
      "seed": 1957939191,
      "version": 193,
      "versionNonce": 1230708697,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784211564167,
      "link": null,
      "locked": false,
      "text": "A watermark tells Flink:\n    \"I believe no more events older than this time will arrive.\"\nEX: \n    Allowed Lateness = 30 sec\n\n9:01:00 -------------------- 9:01:59\n            Window\n\nAt 9:02:00\n    Flink doesn't close the 9:01 window yet\n\nIt waits\n    9:02:10\n    Still waiting...\n\n    9:02:20\n    Still waiting...\n    \n    9:02:30\n    Watermark reached.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A watermark tells Flink:\n    \"I believe no more events older than this time will arrive.\"\nEX: \n    Allowed Lateness = 30 sec\n\n9:01:00 -------------------- 9:01:59\n            Window\n\nAt 9:02:00\n    Flink doesn't close the 9:01 window yet\n\nIt waits\n    9:02:10\n    Still waiting...\n\n    9:02:20\n    Still waiting...\n    \n    9:02:30\n    Watermark reached.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "h9nz0FuQztQhXzdLt28CA",
      "type": "text",
      "x": -943.46875,
      "y": 5774.88671875,
      "width": 294.54376220703125,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
