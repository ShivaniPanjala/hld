    {
      "id": "hvVFZ-IeVZq9zmkVPMwFH",
      "type": "text",
      "x": -1082.962417602539,
      "y": 2753.8085937500005,
      "width": 587.1194458007812,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
