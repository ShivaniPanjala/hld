      "isDeleted": false,
      "boundElements": null,
      "updated": 1784211819690,
      "link": null,
      "locked": false,
      "text": "Uses when the event actually happened, not when it arrived.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Uses when the event actually happened, not when it arrived.",
