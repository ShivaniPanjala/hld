    },
    {
      "id": "FSVjTmok3AdqEY0gwkXed",
      "type": "text",
      "x": -950.22265625,
      "y": 5162.065625,
      "width": 667.5194091796875,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2D",
      "roundness": null,
      "seed": 609583671,
      "version": 38,
      "versionNonce": 2114710007,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784211269808,
      "link": null,
      "locked": false,
      "text": "Imagine events 9:01:58 may arrive 20 seconds late.\n\nIf Flink closes the 9:01 window immediately at 9:02:00, it will miss those late events.\n\nThis is where watermarks help.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Imagine events 9:01:58 may arrive 20 seconds late.\n\nIf Flink closes the 9:01 window immediately at 9:02:00, it will miss those late events.\n\nThis is where watermarks help.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AHDCnX6-ja3TVTZ7iO3B0",
      "type": "text",
      "x": -968.3498062931973,
      "y": 5329.127734375,
      "width": 136.53478765487668,
      "height": 31.085937499999996,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2F",
      "roundness": null,
      "seed": 1875645911,
      "version": 95,
      "versionNonce": 1496077977,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784211310220,
      "link": null,
      "locked": false,
      "text": "WaterMark",
      "fontSize": 27.031249999999993,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WaterMark",
