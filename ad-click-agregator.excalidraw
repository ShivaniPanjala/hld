      "seed": 595486617,
      "version": 71,
      "versionNonce": 545525047,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784211552406,
      "link": null,
      "locked": false,
      "text": "Now Flink says\n    No more 9:01 events are expected.\n    Close window.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Now Flink says\n    No more 9:01 events are expected.\n    Close window.",
